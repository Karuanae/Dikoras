        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "http://127.0.0.1:5000/register", "protocol": "http", "host": ["127.0.0.1"], "port": "5000", "path": ["register"]},
            "body": {"mode": "raw", "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"testpass\",\n  \"role\": \"client\"\n}"}
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
