            "url": {"raw": "http://127.0.0.1:5000/user/1", "protocol": "http", "host": ["127.0.0.1"], "port": "5000", "path": ["user", "1"]},
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"updated@example.com\"\n}"}
          }
        },
        {
          "name": "Delete User",
